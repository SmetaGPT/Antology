APP_NAME=Antology API
APP_ENV=development
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173
PUBLIC_BASE_URL=http://127.0.0.1:8000
DATABASE_PATH=backend/data/leads.db
BOOK_STORAGE_DIR=backend/data/books
DOWNLOAD_TOKEN_TTL_HOURS=72
DELIVERY_DELAY_MINUTES=30
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_USE_TLS=false
EMAIL_MAX_RETRIES=3
WORKER_POLL_INTERVAL_SECONDS=15
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
SECRET_KEY=replace-this-secret
