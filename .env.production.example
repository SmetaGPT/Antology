WEB_PORT=8080
MAILHOG_UI_PORT=8025
RUNTIME_DATA_DIR=./runtime/data
RUNTIME_LOG_DIR=./runtime/logs
CORS_ORIGINS=https://your-domain.example
PUBLIC_BASE_URL=https://your-domain.example
EXPOSE_API_DOCS=false
DOWNLOAD_TOKEN_TTL_HOURS=72
MAX_BOOK_UPLOAD_MB=250
DELIVERY_DELAY_MINUTES=30
RATE_LIMIT_WINDOW_MINUTES=60
RATE_LIMIT_MAX_PER_IP=10
RATE_LIMIT_MAX_PER_EMAIL=3
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=mailer@example.com
SMTP_PASSWORD=replace-me
SMTP_FROM_EMAIL=noreply@example.com
SMTP_USE_TLS=true
EMAIL_MAX_RETRIES=3
WORKER_POLL_INTERVAL_SECONDS=15
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-me
SECRET_KEY=replace-with-a-long-random-secret
